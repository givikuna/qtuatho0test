{
    "tabWidth": 4,
    "printWidth": 110,
    "semi": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "arrowParens": "always",
    "embeddedLanguageFormatting": "auto",
    "singleAttributePerLine": true,
    "bracketSameLine": false,
    "quoteProps": "as-needed",
    "endOfLine": "lf",
    "overrides": [
        {
            "files": ["*.json", "*.jsonc", ".eslintrc", ".prettierrc"],
            "options": {
                "trailingComma": "none"
            }
        }
    ]
}
